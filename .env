# ----------------------------------------------------------------------------
# Foddo environment variables — copy this file to `.env` and fill in values.
# ----------------------------------------------------------------------------

# Database — SQLite (a local file). No DATABASE_URL is required: the path is set
# directly in prisma/schema.prisma, so the app runs anywhere with zero DB config.
# (Only set DATABASE_URL if you switch the schema back to env("DATABASE_URL").)

# Stripe (TEST MODE keys — get them at https://dashboard.stripe.com/test/apikeys)
# If these are left blank, checkout gracefully falls back to a simulated flow.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen` or the Stripe dashboard webhook settings:
STRIPE_WEBHOOK_SECRET=""

# Public base URL (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Admin auth — used to sign the admin session JWT and seed the admin user.
# CHANGE THESE before deploying anywhere.
ADMIN_EMAIL="admin@foddo.dev"
ADMIN_PASSWORD="foddo-admin"
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ----------------------------------------------------------------------------
# Optional integrations — the site runs fully without these. Each feature
# auto-hides or falls back gracefully when its variable is blank.
# ----------------------------------------------------------------------------

# WhatsApp (floating button + "Book via WhatsApp"). Intl format, no + or spaces.
NEXT_PUBLIC_WHATSAPP_NUMBER="15551234663"

# Calendly event URL for the reservations "Calendly" tab.
# e.g. https://calendly.com/your-restaurant/table-booking
NEXT_PUBLIC_CALENDLY_URL=""

# Google Maps embed src (Google Maps > Share > Embed a map > copy src).
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://maps.google.com/maps?q=New+York+NY&z=14&output=embed"

# Google review link (replace placeid with your Google Business Place ID).
# e.g. https://search.google.com/local/writereview?placeid=YOUR_PLACE_ID
NEXT_PUBLIC_GOOGLE_REVIEW_URL=""

# PayPal Smart Buttons — client id is public-safe. https://developer.paypal.com/dashboard
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# Wise bank-transfer link — https://wise.com/pay. Shown as a payment option.
NEXT_PUBLIC_WISE_PAYMENT_LINK=""
