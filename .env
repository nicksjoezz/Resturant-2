# Local dev env — generated by scaffold. See .env.example for docs.
DATABASE_URL="file:./dev.db"

# Leave Stripe keys blank to use the built-in simulated checkout fallback.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

NEXT_PUBLIC_BASE_URL="http://localhost:3000"

ADMIN_EMAIL="admin@foddo.dev"
ADMIN_PASSWORD="foddo-admin"
AUTH_SECRET="dev-only-secret-please-change-me-32chars-minimum-000"

# --- Optional integrations (all auto-hide / fall back gracefully when blank) ---
# WhatsApp number, international format, no + or spaces:
NEXT_PUBLIC_WHATSAPP_NUMBER="15551234663"
# Calendly event URL for the reservations "Calendly" tab:
NEXT_PUBLIC_CALENDLY_URL=""
# Google Maps embed src (Maps > Share > Embed a map):
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://maps.google.com/maps?q=New+York+NY&z=14&output=embed"
# Google review write link (replace placeid with your Google Business Place ID):
NEXT_PUBLIC_GOOGLE_REVIEW_URL=""
# PayPal Smart Buttons (client id is public):
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
# Wise bank-transfer payment link:
NEXT_PUBLIC_WISE_PAYMENT_LINK=""
